#include <Wire.h>
#include <WiFi.h>
#include <esp_now.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_ADXL345_U.h>

Adafruit_ADXL345_Unified accel = Adafruit_ADXL345_Unified(12345);

// Wheelchair ESP32 MAC Address
uint8_t receiverMAC[] = {0xD4, 0xE9, 0xF4, 0x78, 0x4C, 0x1C};

// Structure
typedef struct struct_message {
  char command;
} struct_message;

struct_message sendData;

esp_now_peer_info_t peerInfo;

String currentGesture = "";
String lastGesture = "";

// ESP-NOW Send Callback
void OnDataSent(const esp_now_send_info_t *info, esp_now_send_status_t status) {

  if (status == ESP_NOW_SEND_SUCCESS) {
    Serial.println(">> Sent Successfully");
  } else {
    Serial.println(">> Send Failed");
  }
}

void setup() {

  Serial.begin(115200);

  Wire.begin(21, 22);

  if (!accel.begin()) {
    Serial.println("ADXL345 NOT FOUND!");
    while (1);
  }

  accel.setRange(ADXL345_RANGE_2_G);

  WiFi.mode(WIFI_STA);

  Serial.print("Glove MAC : ");
  Serial.println(WiFi.macAddress());

  if (esp_now_init() != ESP_OK) {
    Serial.println("ESP-NOW Initialization Failed");
    return;
  }

  esp_now_register_send_cb(OnDataSent);

  memcpy(peerInfo.peer_addr, receiverMAC, 6);
  peerInfo.channel = 0;
  peerInfo.encrypt = false;

  if (esp_now_add_peer(&peerInfo) != ESP_OK) {
    Serial.println("Failed to Add Peer");
    return;
  }

  Serial.println("==================================");
  Serial.println(" Glove Ready");
  Serial.println("==================================");
}

void loop() {

  sensors_event_t event;
  accel.getEvent(&event);

  float X = event.acceleration.x;
  float Y = event.acceleration.y;
  float Z = event.acceleration.z;

  currentGesture = "STOP";

  if (Y > 5.5 && Z > 1.0)
    currentGesture = "FORWARD";

  else if (Y < -5.5 && Z > 1.5)
    currentGesture = "BACKWARD";

  else if (X > 6.5 && Z > 1.0)
    currentGesture = "RIGHT";

  else if (X < -5.5 && Z > 1.0)
    currentGesture = "LEFT";

  if (currentGesture != lastGesture) {

    if (currentGesture == "FORWARD")
      sendData.command = 'F';

    else if (currentGesture == "BACKWARD")
      sendData.command = 'B';

    else if (currentGesture == "LEFT")
      sendData.command = 'L';

    else if (currentGesture == "RIGHT")
      sendData.command = 'R';

    else
      sendData.command = 'S';

    esp_now_send(receiverMAC, (uint8_t *)&sendData, sizeof(sendData));

    Serial.print("Gesture : ");
    Serial.println(currentGesture);

    lastGesture = currentGesture;
  }

  delay(100);
}
